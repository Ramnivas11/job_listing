# URL of your Vercel frontend (add after deploying client)
# Use comma-separated values for multiple origins
CLIENT_ORIGIN=https://your-app.vercel.app

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/job_listings?retryWrites=true&w=majority

# Port (Render sets this automatically — do not override)
PORT=5000
